# Backend Environment Variables
DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=wizqueue
DATABASE_USER=wizqueue_user
DATABASE_PASSWORD=secure_password

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=minicpm-v:8b
# Alternative models: llava:latest, llama3.2-vision:latest, llava:13b

NODE_ENV=development
PORT=3000
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=application/pdf

# SMTP (iCloud example)
SMTP_HOST=smtp.mail.me.com
SMTP_PORT=587
SMTP_USER=you@icloud.com
SMTP_PASS=app-specific-password
SMTP_FROM=you@icloud.com

# Company info for invoices
COMPANY_NAME=Wiz3D Prints
COMPANY_EMAIL=you@icloud.com
COMPANY_PHONE=
COMPANY_ADDRESS=
COMPANY_WEBSITE=https://showcase.wiz3dprints.com
COMPANY_PAYPAL=https://su.wiz3dprints.com/print-sorcerer
COMPANY_VENMO=https://su.wiz3dprints.com/forge-magic

# Security
JWT_SECRET=change-me-to-a-random-32-plus-character-string
CORS_ORIGIN=https://tools.wiz3dprints.com
# Service token consumed by wiz3dtools-mcp (Jarvis bridge). Now READ-ONLY
# at the middleware layer — non-GET requests are rejected even with this
# token. See bug #60 lockdown patch series.
# Bootstrap the first admin user. Set to "true" before the very first
# POST /api/auth/register, then UNSET after. With users in the DB this
# flag has no effect; with an empty users table and this flag unset,
# registration returns 503 instead of silently letting the first caller
# become admin. Bug #60 F6 hardening.
ALLOW_BOOTSTRAP=false

# Store API (used by wiz3d-prints to fetch products and submit orders)
STORE_API_KEY=change-me-to-a-random-48-plus-character-string
STORE_IMAGE_PUBLIC_BASE=https://tools.wiz3dprints.com/uploads/store
# Change #148 F7 — per-customer scope for the store API.
# STORE_CUSTOMER_TOKEN_SECRET signs the HMAC token wiz3d-prints fetches
# during consumer login and forwards on every /api/store/* call. Must be
# 32+ chars. Independent of JWT_SECRET (different lifetime, different
# blast radius). ENABLE_STORE_CUSTOMER_TOKEN gates enforcement — leave
# false until wiz3d-prints' consumer flow has shipped the token-fetch
# wiring, then flip true to require the X-Customer-Token header on
# per-customer endpoints.
STORE_CUSTOMER_TOKEN_SECRET=change-me-to-a-random-48-plus-character-string
ENABLE_STORE_CUSTOMER_TOKEN=false

# Product image uploads
MAX_IMAGE_SIZE=5242880

# BamBuddy integration (BuildPlan #6) — wiz3dtools uses these for the
# Phase 4 colors sync (Phase 3 removed the bambu-monitor + dashboard).
# Create the API key in BamBuddy UI → Settings → API Keys, then put the
# value in the on-LXC .env only.
BAMBUDDY_URL=http://192.168.7.147:8000
BAMBUDDY_API_KEY=

# wiz3d-prints admin API — wholesale-user CRUD is proxied through here
# so tools.wiz3dprints.com is the single admin surface (BuildPlan #11).
# Token MUST match `ADMIN_API_TOKEN` in wiz3d-prints' prod .env.
WIZ3D_PRINTS_API_URL=http://192.168.7.245:3000
WIZ3D_PRINTS_ADMIN_TOKEN=change-me-to-a-random-48-plus-character-string

# Zoo-Notifier push hub (BP38 P7) — new orders + paid invoices POST to the
# ecosystem push hub. ZOO_NOTIFIER_URL defaults to the LAN host:port. A blank
# ZOO_NOTIFIER_KEY makes every notify a SILENT no-op (the order/payment flow
# never breaks if the hub is down or un-provisioned). Put the real per-source
# key (zn_…) in the on-LXC .env only.
ZOO_NOTIFIER_URL=http://192.168.7.84:3030
ZOO_NOTIFIER_KEY=

# Frontend Environment Variables
VITE_API_URL=http://localhost:3000/api
